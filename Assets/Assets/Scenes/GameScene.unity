--- !u!114 &1371498513
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1371498511}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ce2de6203f3dcb044ae480178c6402d0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogNPC
  dialogUI: {fileID: 786772475}
  dialogText: {fileID: 1061398010}
  lines:
  - "\u0E02\u0E49\u0E32\u0E40\u0E2B\u0E47\u0E19\u0E40\u0E28\u0E29\u0E0B\u0E32\u0E01\u0E02\u0E2D\u0E07\u0E1E\u0E25\u0E31\u0E07\u0E18\u0E32\u0E15\u0E38\u0E44\u0E1F\u0E44\u0E2B\u0E25\u0E40\u0E02\u0E49\u0E32\u0E44\u0E1B\u0E43\u0E19\u0E15\u0E31\u0E27\u0E40\u0E08\u0E49\u0E32...\u0E40\u0E08\u0E49\u0E32\u0E04\u0E07\u0E40\u0E1B\u0E47\u0E19
    Elementalist \u0E40\u0E2B\u0E21\u0E37\u0E2D\u0E19\u0E01\u0E31\u0E19\u0E2A\u0E34\u0E19\u0E30"
  - "\u0E02\u0E49\u0E32\u0E19\u0E36\u0E01\u0E27\u0E48\u0E32\u0E40\u0E08\u0E49\u0E32\u0E08\u0E30\u0E15\u0E32\u0E22\u0E44\u0E1B\u0E41\u0E25\u0E49\u0E27\u0E0B\u0E30\u0E2D\u0E35\u0E01\u0E19\u0E30
    \u0E2E\u0E48\u0E32\u0E46! \u0E40\u0E08\u0E49\u0E32\u0E19\u0E35\u0E48\u0E41\u0E1B\u0E25\u0E01\u0E08\u0E23\u0E34\u0E07\u0E46"
  - "\u0E23\u0E31\u0E1A\u0E19\u0E35\u0E48\u0E44\u0E1B\u0E2A\u0E34  [ \u0E08\u0E34\u0E49\u0E07\u0E08\u0E2D\u0E01\u0E44\u0E14\u0E49\u0E23\u0E31\u0E1A\u0E2A\u0E33\u0E23\u0E31\u0E1A\u0E01\u0E32\u0E23\u0E4C\u0E14
    ] "
  - "\u0E2A\u0E34\u0E48\u0E07\u0E19\u0E35\u0E49\u0E40\u0E1B\u0E47\u0E19\u0E2B\u0E19\u0E36\u0E48\u0E07\u0E43\u0E19\u0E2D\u0E38\u0E1B\u0E01\u0E23\u0E13\u0E4C\u0E40\u0E27\u0E17\u0E21\u0E19\u0E15\u0E4C\u0E17\u0E35\u0E48\u0E16\u0E39\u0E01\u0E2D\u0E2D\u0E01\u0E41\u0E1A\u0E1A\u0E21\u0E32\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E08\u0E31\u0E14\u0E01\u0E32\u0E23\u0E01\u0E31\u0E1A\u0E40\u0E2B\u0E25\u0E48\u0E32
    Devourer \u0E42\u0E14\u0E22\u0E40\u0E09\u0E1E\u0E32\u0E30"
  - "\u0E09\u0E31\u0E19\u0E43\u0E0A\u0E49\u0E44\u0E21\u0E48\u0E16\u0E19\u0E31\u0E14\u0E2B\u0E23\u0E2D\u0E01
    \u0E09\u0E31\u0E19\u0E0A\u0E2D\u0E1A\u0E14\u0E32\u0E1A\u0E43\u0E2B\u0E0D\u0E48\u0E46\u0E17\u0E35\u0E48\u0E2D\u0E22\u0E39\u0E48\u0E14\u0E49\u0E32\u0E19\u0E2B\u0E25\u0E31\u0E07\u0E02\u0E49\u0E32\u0E21\u0E32\u0E01\u0E01\u0E27\u0E48\u0E32\u0E19\u0E48\u0E30
    \u0E2E\u0E48\u0E32\u0E46!"
  - "[\u0E01\u0E14 Q,E \u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E40\u0E25\u0E37\u0E2D\u0E01
    \u0E01\u0E14 J \u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E43\u0E0A\u0E49] "
  - "\u0E1E\u0E27\u0E01\u0E40\u0E23\u0E32\u0E40\u0E2B\u0E25\u0E48\u0E32 Elementalist
    \u0E15\u0E48\u0E2D\u0E2A\u0E39\u0E49\u0E01\u0E31\u0E1A\u0E40\u0E2B\u0E25\u0E48\u0E32\u0E2A\u0E31\u0E15\u0E27\u0E4C\u0E1B\u0E23\u0E30\u0E2B\u0E25\u0E32\u0E14\u0E40\u0E2B\u0E25\u0E48\u0E32\u0E19\u0E31\u0E49\u0E19\u0E21\u0E32\u0E19\u0E32\u0E19\u0E19\u0E31\u0E1A\u0E1B\u0E35\u0E41\u0E25\u0E49\u0E27"
  - "\u0E41\u0E15\u0E48\u0E2B\u0E25\u0E31\u0E07\u0E46\u0E21\u0E32\u0E1E\u0E27\u0E01\u0E40\u0E23\u0E32\u0E01\u0E47\u0E40\u0E2B\u0E25\u0E37\u0E2D\u0E40\u0E1E\u0E35\u0E22\u0E07\u0E2B\u0E22\u0E34\u0E1A\u0E21\u0E37\u0E2D\u0E40\u0E17\u0E48\u0E32\u0E19\u0E31\u0E49\u0E19\u0E40\u0E2D\u0E07"
  - ...
  - "\u0E40\u0E2D\u0E32\u0E25\u0E48\u0E30\u0E09\u0E31\u0E19\u0E15\u0E49\u0E2D\u0E07\u0E44\u0E1B\u0E41\u0E25\u0E49\u0E27
    \u0E21\u0E35\u0E1E\u0E27\u0E01\u0E2A\u0E31\u0E15\u0E27\u0E4C\u0E1B\u0E23\u0E30\u0E2B\u0E25\u0E32\u0E14\u0E08\u0E2D\u0E21\u0E15\u0E23\u0E30\u0E01\u0E30\u0E2D\u0E35\u0E01\u0E40\u0E1B\u0E47\u0E19\u0E42\u0E02\u0E43\u0E2B\u0E49\u0E44\u0E1B\u0E08\u0E31\u0E14\u0E01\u0E32\u0E23\u0E19\u0E48\u0E30"
  - "\u0E44\u0E27\u0E49\u0E40\u0E08\u0E2D\u0E01\u0E31\u0E19\u0E43\u0E2B\u0E21\u0E48\u0E19\u0E30"
  talkHint: {fileID: 1778876001}
  checkpointPoint: {fileID: 1371498512}
