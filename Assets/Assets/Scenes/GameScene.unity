--- !u!114 &1978811076
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1978811074}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ce2de6203f3dcb044ae480178c6402d0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogNPC
  dialogUI: {fileID: 715567677}
  dialogText: {fileID: 769540632}
  lines:
  - "\u0E42\u0E2D\u0E49 \u0E44\u0E07! \u0E1E\u0E27\u0E01\u0E40\u0E23\u0E32\u0E40\u0E08\u0E2D\u0E01\u0E31\u0E19\u0E2D\u0E35\u0E01\u0E41\u0E25\u0E49\u0E27\u0E19\u0E30"
  - "\u0E40\u0E08\u0E49\u0E32\u0E40\u0E01\u0E48\u0E07\u0E21\u0E32\u0E01\u0E40\u0E25\u0E22\u0E17\u0E35\u0E48\u0E21\u0E32\u0E16\u0E36\u0E07\u0E17\u0E35\u0E48\u0E19\u0E35\u0E48\u0E44\u0E14\u0E49
    \u0E44\u0E21\u0E48\u0E40\u0E04\u0E22\u0E21\u0E35\u0E43\u0E04\u0E23\u0E21\u0E32\u0E44\u0E14\u0E49\u0E44\u0E01\u0E25\u0E02\u0E19\u0E32\u0E14\u0E19\u0E35\u0E49\u0E19\u0E2D\u0E01\u0E08\u0E32\u0E01\u0E1E\u0E27\u0E01\u0E40\u0E23\u0E32"
  - "\u0E16\u0E32\u0E21\u0E27\u0E48\u0E32\u0E41\u0E25\u0E49\u0E27\u0E09\u0E31\u0E19\u0E21\u0E32\u0E44\u0E14\u0E49\u0E22\u0E31\u0E07\u0E44\u0E07\u0E2B\u0E23\u0E2D?
    \u0E2D\u0E35\u0E01\u0E1D\u0E31\u0E48\u0E07\u0E21\u0E31\u0E19\u0E21\u0E35\u0E25\u0E34\u0E1F\u0E17\u0E4C\u0E2D\u0E35\u0E01\u0E15\u0E31\u0E27\u0E2B\u0E19\u0E36\u0E48\u0E07\u0E19\u0E48\u0E30
    \u0E2E\u0E48\u0E32\u0E46!"
  - .....
  - "\u0E22\u0E31\u0E07\u0E44\u0E07\u0E01\u0E47\u0E40\u0E16\u0E2D\u0E30 \u0E09\u0E31\u0E19\u0E0A\u0E37\u0E48\u0E2D
    Kael \u0E19\u0E30 \u0E02\u0E2D\u0E42\u0E17\u0E29\u0E17\u0E35\u0E48\u0E44\u0E21\u0E48\u0E41\u0E19\u0E30\u0E19\u0E33\u0E15\u0E31\u0E27\u0E43\u0E2B\u0E49\u0E40\u0E23\u0E47\u0E27\u0E01\u0E27\u0E48\u0E32\u0E19\u0E35\u0E49"
  - "\u0E40\u0E2D\u0E32\u0E25\u0E48\u0E30 \u0E40\u0E08\u0E49\u0E32\u0E01\u0E47\u0E23\u0E30\u0E27\u0E31\u0E07\u0E15\u0E31\u0E27\u0E44\u0E27\u0E49\u0E41\u0E25\u0E49\u0E27\u0E01\u0E31\u0E19
    \u0E1E\u0E27\u0E01\u0E40\u0E23\u0E32\u0E44\u0E21\u0E48\u0E23\u0E39\u0E49\u0E27\u0E48\u0E32\u0E17\u0E35\u0E48\u0E19\u0E35\u0E48\u0E2D\u0E31\u0E19\u0E15\u0E23\u0E32\u0E22\u0E41\u0E04\u0E48\u0E44\u0E2B\u0E19"
  - "\u0E09\u0E31\u0E19\u0E08\u0E30\u0E41\u0E22\u0E01\u0E44\u0E1B\u0E2A\u0E33\u0E23\u0E27\u0E08\u0E14\u0E39\u0E2D\u0E35\u0E01\u0E1D\u0E31\u0E48\u0E07\u0E40\u0E1C\u0E37\u0E48\u0E2D\u0E08\u0E30\u0E21\u0E35\u0E1E\u0E27\u0E01\u0E2A\u0E31\u0E15\u0E27\u0E4C\u0E1B\u0E23\u0E30\u0E2B\u0E25\u0E32\u0E14\u0E43\u0E2B\u0E49\u0E1F\u0E32\u0E14\u0E40\u0E25\u0E48\u0E19\u0E41\u0E25\u0E49\u0E27\u0E01\u0E31\u0E19\u0E19\u0E30"
  - "\u0E22\u0E31\u0E07\u0E44\u0E07\u0E01\u0E47\u0E40\u0E16\u0E2D\u0E30 \u0E09\u0E31\u0E19\u0E0A\u0E37\u0E48\u0E2D
    Kael \u0E19\u0E30 \u0E02\u0E2D\u0E42\u0E17\u0E29\u0E17\u0E35\u0E48\u0E44\u0E21\u0E48\u0E41\u0E19\u0E30\u0E19\u0E33\u0E15\u0E31\u0E27\u0E43\u0E2B\u0E49\u0E40\u0E23\u0E47\u0E27\u0E01\u0E27\u0E48\u0E32\u0E19\u0E35\u0E49"
  - "\u0E02\u0E49\u0E32\u0E07\u0E2B\u0E19\u0E49\u0E32\u0E21\u0E35\u0E1A\u0E2D\u0E2A\u0E17\u0E35\u0E48\u0E14\u0E39\u0E14\u0E1E\u0E25\u0E31\u0E07\u0E40\u0E07\u0E32\u0E02\u0E2D\u0E07\u0E40\u0E08\u0E49\u0E32\u0E44\u0E1B\u0E2D\u0E22\u0E39\u0E48"
  - "\u0E23\u0E30\u0E27\u0E31\u0E07\u0E15\u0E31\u0E27\u0E14\u0E49\u0E27\u0E22\u0E25\u0E48\u0E30"
  - "\u0E42\u0E0A\u0E04\u0E14\u0E35\u0E19\u0E30\u0E04\u0E39\u0E48\u0E2B\u0E39!"
  talkHint: {fileID: 1778876001}
