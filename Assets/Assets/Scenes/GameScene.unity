  m_Script: {fileID: 11500000, guid: ce2de6203f3dcb044ae480178c6402d0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SimpleDialogNPC
  dialogUI: {fileID: 53324334}
  dialogText: {fileID: 145946228}
  lines:
  - "\u0E40\u0E08\u0E2D\u0E01\u0E31\u0E19\u0E2D\u0E35\u0E01\u0E41\u0E25\u0E49\u0E27\u0E19\u0E30\u0E04\u0E39\u0E48\u0E2B\u0E39!"
  - "\u0E02\u0E49\u0E32\u0E07\u0E2B\u0E19\u0E49\u0E32\u0E19\u0E31\u0E49\u0E19\u0E04\u0E37\u0E2D
    The Mother"
  - "\u0E1C\u0E39\u0E49\u0E17\u0E35\u0E48\u0E0A\u0E34\u0E07\u0E1E\u0E25\u0E31\u0E07\u0E18\u0E32\u0E15\u0E38\u0E19\u0E49\u0E33\u0E44\u0E1B\u0E08\u0E32\u0E01\u0E40\u0E08\u0E49\u0E32"
  - "\u0E40\u0E08\u0E49\u0E32\u0E19\u0E35\u0E48\u0E41\u0E02\u0E47\u0E07\u0E41\u0E01\u0E23\u0E48\u0E07\u0E21\u0E32\u0E01"
  - "\u0E02\u0E49\u0E32\u0E01\u0E47\u0E2D\u0E22\u0E32\u0E01\u0E08\u0E30\u0E2B\u0E49\u0E32\u0E21\u0E40\u0E08\u0E49\u0E32\u0E19\u0E30"
  - "\u0E41\u0E15\u0E48..."
  - "\u0E09\u0E32\u0E01\u0E1D\u0E35\u0E21\u0E37\u0E2D\u0E02\u0E2D\u0E07\u0E40\u0E08\u0E49\u0E32"
  - "\u0E40\u0E08\u0E49\u0E32\u0E04\u0E07\u0E41\u0E02\u0E47\u0E07\u0E41\u0E01\u0E23\u0E48\u0E07\u0E1E\u0E2D\u0E41\u0E25\u0E49\u0E27\u0E25\u0E30"
  - "\u0E42\u0E0A\u0E04\u0E14\u0E35\u0E19\u0E30\u0E04\u0E39\u0E48\u0E2B\u0E39!"
  talkHint: {fileID: 1778876001}
  checkpointPoint: {fileID: 1707973464}
